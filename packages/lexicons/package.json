{
  "name": "@singi-labs/doom-lexicons",
  "version": "0.1.0",
  "description": "AT Protocol lexicon schemas for Doom over AT Protocol",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "lexicons"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "generate": "node scripts/generate.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atproto/lexicon": "0.6.2",
    "@atproto/xrpc-server": "^0.10.18",
    "multiformats": "^13.4.2",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@atproto/lex-cli": "0.9.9",
    "@types/node": "22.15.3",
    "eslint": "9.27.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.1",
    "vitest": "3.1.4"
  }
}
