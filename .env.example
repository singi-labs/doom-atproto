# AT Protocol credentials for the game server bot
ATP_SERVICE=https://bsky.social
ATP_IDENTIFIER=doom-server.bsky.social
ATP_PASSWORD=your-app-password

# Player DID (the server accepts inputs from this player)
PLAYER_DID=did:plc:your-player-did

# Path to DOOM1.WAD shareware file
WAD_PATH=doom1.wad

# Game server DID (the client subscribes to frames from this server)
SERVER_DID=did:plc:your-server-did
